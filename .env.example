# Deployment to Vercel
# 1. VITE_GEMINI_API_KEY: Your secret key from https://aistudio.google.com/app/apikey (REQUIRED)
# 2. VITE_APP_URL: Your web address (e.g., https://my-app.vercel.app). Used for the "Share" link functionality. (OPTIONAL)

VITE_GEMINI_API_KEY="PASTE_YOUR_KEY_HERE"
VITE_APP_URL="https://your-project.vercel.app"
